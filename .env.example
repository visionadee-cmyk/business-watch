# Firebase Configuration
# Copy this file to .env and fill in your actual Firebase credentials

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Notification & Email Configuration
# SMTP settings for sending deadline/bid alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=alerts@businesswatch.mv
ADMIN_EMAIL=admin@businesswatch.mv

# Cron Job Security (generate a random string)
CRON_SECRET=your-random-secret-key-here

# Optional: SMS Configuration (for future SMS alerts)
# SMS_API_KEY=your-sms-api-key
# SMS_SENDER_ID=BusinessWatch
