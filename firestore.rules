rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access, require auth for writes
    match /tenders/{tenderId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allow public read access to tender metadata and summary
    match /tenderData/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default - require auth for all other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
